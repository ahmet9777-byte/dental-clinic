# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dental_clinic
DB_USER=postgres
DB_PASSWORD=yourpassword

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=24h

# ─────────────────────────────────────────────
# n8n Automation
# ─────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/appointment-confirmed

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
